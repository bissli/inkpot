    "highlight.decorations": { "rangeBehavior": 3 },
    "highlight.regexFlags": "gim",
    "highlight.minDelay": 5,
    "highlight.maxMatches": 999,
    "highlight.regexes": {
        // String background
        "(?<!\\w)(?:[frb])?(('''|\"\"\")((?:(?!\\2)[\\s\\S])*?)\\2|'([^'\\\\]|\\\\.)*'|\"([^\"\\\\]|\\\\.)*\")": {
            "regexFlags": "gms",
            "decorations": [
                { "color": "#ffcd8b", "backgroundColor": "#404040" }
            ]
        },
        // Character escapes like \n \t etc
        "\\\\[a-z]": { "color": "#c080d0" },
        // Git diff markers
        "^\\+.*": { "color": "#ffffcd" },
        "^-.*": { "color": "#ffffcd" },
        "^@@.*@@": { "color": "#ffffcd" },
        // Git conflict markers
        "^<<<<<<<.*": { "color": "#ffffff" },
        "^=======.*": { "color": "#ffffff" },
        "^>>>>>>>.*": { "color": "#ffffff" }
    },
    "git.autoRepositoryDetection": true,
    "git.detectSubmodules": true,
    "git.scanRepositories": [
        "..",
        "../..",
        "../../.."
    ],
    "editor.tokenColorCustomizations": {
        // Basic token colors
        "comments": "#cd8b00",
        "numbers": "#f0ad6d",
        "keywords": "#808bed",
        "types": "#808bed",
        "functions": "#ff8bff",
        "variables": "#cfbfad",
        // TextMate token rules
        "textMateRules": [
            { "scope": "constant.character", "settings": { "foreground": "#ffcd8b" } },
            { "scope": "entity.name.tag", "settings": { "foreground": "#808bed" } },
            { "scope": "entity.other.attribute-name", "settings": { "foreground": "#ff8bff" } },
            { "scope": "meta.preprocessor", "settings": { "foreground": "#409090" } },
            { "scope": "support.constant", "settings": { "foreground": "#ffcd8b" } },
            { "scope": "support.function", "settings": { "foreground": "#ff8bff" } },
            { "scope": "support.function.builtin", "settings": { "foreground": "#ff8bff" } },
            { "scope": "entity.name.function.member", "settings": { "foreground": "#ff8bff" } },
            { "scope": ["keyword.control.import", "constant.language.import-export"], "settings": { "foreground": "#409090" } }, // "moss green color from vim"
            { "scope": "keyword.control.flow", "settings": { "foreground": "#808bed" } },
            { "scope": "storage.type.function", "settings": { "foreground": "#808bed" } },
            { "scope": ["keyword.control", "keyword.operator.logical", "keyword.operator.word", "keyword.operator.logical.python"], "settings": { "foreground": "#808bed" } },
            { "scope": "variable.language.special", "settings": { "foreground": "#cfbfad" } },
            { "scope": "constant.language.python", "settings": { "foreground": "#ff8bff" } },
            { "scope": "support.variable.magic", "settings": { "foreground": "#cfbfad" } },
            { "scope": "punctuation", "settings": { "foreground": "#cfbfad" } },
            { "scope": "punctuation.definition.parameters", "settings": { "foreground": "#cfbfad" } },
            { "scope": "punctuation.definition.bracket", "settings": { "foreground": "#cfbfad" } },
            { "scope": "punctuation.definition.block", "settings": { "foreground": "#cfbfad" } },
            { "scope": "meta.brace", "settings": { "foreground": "#cfbfad" } },
            { "scope": "punctuation.definition.dictionary", "settings": { "foreground": "#cfbfad" } },
            { "scope": "punctuation.definition.array", "settings": { "foreground": "#cfbfad" } },
            { "scope": "punctuation.section", "settings": { "foreground": "#cfbfad" } },
            { "scope": "variable.parameter", "settings": { "foreground": "#cfbfad" } },
            { "scope": "support.function.magic", "settings": { "foreground": "#ff8bff" } },
            { "scope": "storage.type", "settings": { "foreground": "#808bed" } },
            { "scope": "support.type", "settings": { "foreground": "#ff8bff" } },
            { "scope": "support.class", "settings": { "foreground": "#808bed" } },
            { "scope": "keyword.operator", "settings": { "foreground": "#cfbfad" } },
            { "scope": "constant.numeric", "settings": { "foreground": "#ffcd8b" } },
            { "scope": "conflict.begin", "settings": { "foreground": "#ffffff" } },
            { "scope": "conflict.ours", "settings": { "foreground": "#ffffff" } },
            { "scope": "conflict.theirs", "settings": { "foreground": "#ffffff" } },
            { "scope": "conflict.end", "settings": { "foreground": "#ffffff" } },
            { "scope": "meta.diff.header", "settings": { "foreground": "#ffffcd" } },
            { "scope": "markup.deleted", "settings": { "foreground": "#ffffcd" } },
            { "scope": "markup.inserted", "settings": { "foreground": "#ffffcd" } },
            { "scope": "markup.changed", "settings": { "foreground": "#ffffcd" } },
            { "scope": "markup.quote", "settings": { "foreground": "#409090" } },
            { "scope": "comment.documentation", "settings": { "foreground": "#ad7b20" } },
            { "scope": "comment.documentation.parameter", "settings": { "foreground": "#fdd090" } },
            { "scope": ["constant", "variable.other"], "settings": { "foreground": "#cfbfad" } },
            { "scope": "entity.name.type", "settings": { "foreground": "#ff8bff" } },
            { "scope": "entity.name.function", "settings": { "foreground": "#ff8bff" } },
            { "scope": "markup.underline", "settings": { "foreground": "#df9f2d", "fontStyle": "bold underline" } },
            { "scope": "markup.bold", "settings": { "fontStyle": "bold" } },
            { "scope": "variable.parameter", "settings": { "foreground": "#cfbfad" } },
            { "scope": "constant.character.escape", "settings": { "foreground": "#c080d0" } },
            // Semantic token colors moved from semanticTokenColors
            { "scope": "variable", "settings": { "foreground": "#cfbfad" } },
            { "scope": "variable.defaultLibrary", "settings": { "foreground": "#cfbfad" } },
            { "scope": "parameter", "settings": { "foreground": "#cfbfad" } },
            { "scope": "parameter.declaration", "settings": { "foreground": "#cfbfad" } },
            { "scope": "selfParameter", "settings": { "foreground": "#cfbfad" } },
            { "scope": "property", "settings": { "foreground": "#cfbfad" } },
            { "scope": "function", "settings": { "foreground": "#ff8bff" } },
            { "scope": "function.builtin", "settings": { "foreground": "#ff8bff" } },
            { "scope": "method", "settings": { "foreground": "#ff8bff" } },
            { "scope": "event", "settings": { "foreground": "#ff8bff" } },
            { "scope": "class", "settings": { "foreground": "#808bed" } },
            { "scope": "keyword", "settings": { "foreground": "#808bed" } },
            { "scope": "modifier", "settings": { "foreground": "#808bed" } },
            { "scope": "enumMember", "settings": { "foreground": "#ffcd8b" } }
        ]
    }
}
